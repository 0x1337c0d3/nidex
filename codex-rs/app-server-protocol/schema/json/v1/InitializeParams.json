{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ClientInfo": {
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "type": "object"
    },
    "InitializeCapabilities": {
      "description": "Client-declared capabilities negotiated during initialize.",
      "properties": {
        "experimentalApi": {
          "default": false,
          "description": "Opt into receiving experimental API methods and fields.",
          "type": "boolean"
        },
        "terminal": {
          "default": false,
          "description": "Client supports delegated terminal execution (`terminal/*` server→client requests).",
          "type": "boolean"
        }
      },
      "type": "object"
    }
  },
  "properties": {
    "clientCapabilities": {
      "anyOf": [
        {
          "$ref": "#/definitions/InitializeCapabilities"
        },
        {
          "type": "null"
        }
      ]
    },
    "clientInfo": {
      "anyOf": [
        {
          "$ref": "#/definitions/ClientInfo"
        },
        {
          "type": "null"
        }
      ]
    },
    "protocolVersion": {
      "description": "ACP protocol version the client wishes to use. Stored as raw JSON so we can echo back the exact type (integer or string) the client sent."
    }
  },
  "title": "InitializeParams",
  "type": "object"
}