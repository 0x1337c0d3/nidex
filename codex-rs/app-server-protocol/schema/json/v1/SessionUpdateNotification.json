{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AcpContentBlock": {
      "description": "A single ACP content block inside a `session/update` agentMessage update.",
      "oneOf": [
        {
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "enum": [
                "text"
              ],
              "title": "TextAcpContentBlockType",
              "type": "string"
            }
          },
          "required": [
            "text",
            "type"
          ],
          "title": "TextAcpContentBlock",
          "type": "object"
        }
      ]
    },
    "SessionUpdatePayload": {
      "description": "Tagged payload for the ACP `session/update` server→client notification.",
      "oneOf": [
        {
          "description": "Streaming assistant text delta.",
          "properties": {
            "content": {
              "items": {
                "$ref": "#/definitions/AcpContentBlock"
              },
              "type": "array"
            },
            "role": {
              "type": "string"
            },
            "type": {
              "enum": [
                "agentMessage"
              ],
              "title": "AgentMessageSessionUpdatePayloadType",
              "type": "string"
            }
          },
          "required": [
            "content",
            "role",
            "type"
          ],
          "title": "AgentMessageSessionUpdatePayload",
          "type": "object"
        },
        {
          "description": "Turn ended with an error.",
          "properties": {
            "error": {
              "type": "string"
            },
            "type": {
              "enum": [
                "error"
              ],
              "title": "ErrorSessionUpdatePayloadType",
              "type": "string"
            }
          },
          "required": [
            "error",
            "type"
          ],
          "title": "ErrorSessionUpdatePayload",
          "type": "object"
        }
      ]
    }
  },
  "description": "Params for the ACP `session/update` server→client notification.",
  "properties": {
    "sessionId": {
      "type": "string"
    },
    "update": {
      "$ref": "#/definitions/SessionUpdatePayload"
    }
  },
  "required": [
    "sessionId",
    "update"
  ],
  "title": "SessionUpdateNotification",
  "type": "object"
}