{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AcpContentBlock": {
      "description": "A single ACP content block inside a `session/update` notification. Matches the ACP `ContentBlock` wire format: `{\"type\": \"text\", \"text\": \"...\"}`.",
      "oneOf": [
        {
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "enum": [
                "text"
              ],
              "title": "TextAcpContentBlockType",
              "type": "string"
            }
          },
          "required": [
            "text",
            "type"
          ],
          "title": "TextAcpContentBlock",
          "type": "object"
        }
      ]
    },
    "SessionUpdatePayload": {
      "description": "Tagged payload for the ACP `session/update` server→client notification. Matches the ACP `SessionUpdate` wire format with `\"sessionUpdate\"` discriminant.",
      "oneOf": [
        {
          "description": "A chunk of the agent's response (text content).",
          "properties": {
            "content": {
              "$ref": "#/definitions/AcpContentBlock"
            },
            "sessionUpdate": {
              "enum": [
                "agent_message_chunk"
              ],
              "type": "string"
            }
          },
          "required": [
            "content",
            "sessionUpdate"
          ],
          "type": "object"
        },
        {
          "description": "Turn ended with an error.",
          "properties": {
            "error": {
              "type": "string"
            },
            "sessionUpdate": {
              "enum": [
                "error"
              ],
              "type": "string"
            }
          },
          "required": [
            "error",
            "sessionUpdate"
          ],
          "type": "object"
        }
      ]
    }
  },
  "description": "Params for the ACP `session/update` server→client notification.",
  "properties": {
    "sessionId": {
      "type": "string"
    },
    "update": {
      "$ref": "#/definitions/SessionUpdatePayload"
    }
  },
  "required": [
    "sessionId",
    "update"
  ],
  "title": "SessionUpdateNotification",
  "type": "object"
}
